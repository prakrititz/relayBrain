{
  "platform": "Antigravity",
  "workspace_mapping": {
    "location": "Internal state / config",
    "format": "URI -> CorpusName (e.g. C:\\Users\\... -> prakrititz/OrbitOS)",
    "session_link": "Conversations are mapped by a unique Conversation ID (brain UUID)."
  },
  "transcripts": [
    "~/.gemini/antigravity-ide/brain/[Conversation ID]/.system_generated/logs/transcript.jsonl"
  ],
  "plans": [
    "~/.gemini/antigravity-ide/brain/[Conversation ID]/artifacts/implementation_plan.md",
    "~/.gemini/antigravity-ide/brain/[Conversation ID]/artifacts/implementation_plan.md.metadata.json"
  ],
  "artifacts": [
    "~/.gemini/antigravity-ide/brain/[Conversation ID]/artifacts/*.md",
    "~/.gemini/antigravity-ide/brain/[Conversation ID]/artifacts/*.metadata.json",
    "~/.gemini/antigravity-ide/brain/[Conversation ID]/media_*.png",
    "~/.gemini/antigravity-ide/brain/[Conversation ID]/walkthrough.md"
  ],
  "tasks": [
    "~/.gemini/antigravity-ide/brain/[Conversation ID]/artifacts/task.md"
  ],
  "memory": [
    "~/.gemini/antigravity-ide/knowledge/[KI_ID]/metadata.json",
    "~/.gemini/antigravity-ide/knowledge/[KI_ID]/artifacts/"
  ],
  "tool_calls": [
    "~/.gemini/antigravity-ide/brain/[Conversation ID]/.system_generated/tasks/*.log"
  ],
  "code_changes": [
    "~/.gemini/antigravity-ide/brain/[Conversation ID]/artifacts/walkthrough.md (summarizes changes)"
  ],
  "git_state": [],
  "checkpoints": [],
  "sessions": [
    "~/.gemini/antigravity-ide/brain/[Conversation ID]/"
  ],
  "version_control": [],
  "high_value_targets": [
    "~/.gemini/antigravity-ide/brain/[Conversation ID]/.system_generated/messages/*.json",
    "~/.gemini/antigravity-ide/brain/[Conversation ID]/scratch/*"
  ],
  "recommended_extractors": [
    "Parse the transcript.jsonl for all dialogue and tool actions.",
    "Monitor the artifacts/ directory to capture stateful plans, tasks, and output generated by the agent.",
    "Parse the .system_generated/tasks/ directory to capture full terminal execution history and outputs.",
    "Monitor .system_generated/messages/ for internal system state (like timers, subagent interactions)."
  ]
}
